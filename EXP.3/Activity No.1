#A shop prints multiple copies of receipts. Use nested loops to print item num
"""
Created on Mon Apr 13 00:05:34 2026

@author: Shraddha
"""

num_receipts = 2

items_per_receipt = 2

for receipt_num in range(1, num_receipts + 1):
    print(f"--- Receipt #{receipt_num}---")

    for item_num in range(1, items_per_receipt + 1):
        print(f"Item {item_num}")
    print()
