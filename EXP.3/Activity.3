#A ticket booking system repeats seat display pattern using loops.
"""
Created on Mon Apr 13 00:35:04 2026

@author: Shraddha
"""

rows = 5
seats_per_row = 8

for r in range(1, rows + 1):
    print(f"Row {r}: ", end="")

    for s in range(1, seats_per_row + 1):
        print(f"[{s}]", end="")
    print()
