#A school generates multiplication tables for students from 1 to 10.
"""
Created on Mon Apr 13 00:24:49 2026

@author: Shraddha
"""

for i in range(1, 11):
    print(f"Multiplication Table for {i}:")

    for j in range(1, 11):
        result = i * j
        print(f"{i} * {j} = {result}")
        
    print("_" * 15)        
